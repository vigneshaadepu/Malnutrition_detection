{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nutriscan-ai",
  "compatibility_date": "2026-03-01",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "nutriscan-production",
      "database_id": "placeholder-will-be-replaced-on-deploy"
    }
  ]
}
