{
  "name": "nutriscan-ai",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:sandbox": "wrangler pages dev dist --d1=nutriscan-production --local --ip 0.0.0.0 --port 3000",
    "build": "vite build",
    "preview": "wrangler pages dev dist",
    "deploy": "npm run build && wrangler pages deploy dist --project-name nutriscan-ai",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:migrate:local": "wrangler d1 migrations apply nutriscan-production --local",
    "db:migrate:prod": "wrangler d1 migrations apply nutriscan-production",
    "db:seed": "wrangler d1 execute nutriscan-production --local --file=./seed.sql",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && npm run db:migrate:local",
    "git:init": "git init && git add . && git commit -m 'Initial NutriScan AI commit'"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "hono": "^4.12.3",
    "puppeteer": "^24.41.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260305.0",
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
